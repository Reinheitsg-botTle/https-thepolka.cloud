# ~/.cloudflared/config.yml
# Single tunnel serving both hostnames.
# Run: cloudflared tunnel run thepolka-cloud

tunnel: thepolka-cloud
credentials-file: /home/bball_1181/.cloudflared/thepolka-cloud.json

ingress:

  - hostname: x.thepolka.cloud
    service: http://localhost:8008
  - hostname: store.thepolka.cloud
    service: http://localhost:8007
  - hostname: mail-ecosystem.thepolka.cloud
    service: http://localhost:8006
  - hostname: directory-app.thepolka.cloud
    service: http://localhost:8005
  - hostname: http://CAD.thepolka.cloud
    service: http://localhost:8004
  - hostname: faire.thepolka.cloud
    service: http://localhost:8003
  - hostname: resume-generator.thepolka.cloud
    service: http://localhost:8002
  - hostname: thepolka.cloud
    service: http://localhost:8001
  - hostname: www.thepolka.cloud
    service: http://localhost:8001
  - service: http_status:404
