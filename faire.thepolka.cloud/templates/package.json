{
  "name": "orb-widget",
  "version": "2.0.0",
  "description": "Hi, I'm Faire. I am your AI Desktop OS Overlay · Full screen AI layer beyond the browser",
  "main": "main.js",
  "author": "Orb Cofounders",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "backend": "node backend/server.js",
    "dev:all": "concurrently \"node backend/server.js\" \"cross-env NODE_ENV=development electron .\"",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --mac --win --linux"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "express": "^4.18.2",
    "node-fetch": "^3.3.2",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.faire.orb",
    "productName": "Orb",
    "copyright": "Copyright © 2025 Orb",
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "assets/icon.png"
    }
  }
}

