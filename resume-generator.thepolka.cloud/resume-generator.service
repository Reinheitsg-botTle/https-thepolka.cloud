[Unit]
Description=Résumé Generator, https://resume-generator - thepolka.cloud
After=network.target

[Service]
Type=simple
User=bball_1181
WorkingDirectory=/home/bball_1181/thepolka.cloud/resume-generator.thepolka.cloud
sudo sed i '/^ExecStart=/c\ExecStart=/home/bball/thepolka.cloud/resume-generator.thepolka.cloud/.venv/bin/python app.py
Restart=on-failure
RestartSec=5
Environment=PORT=5000

[Install]
WantedBy=multi-user.target
